{
  "name": "waas-website",
  "version": "0.0.0",
  "private": true,
  "description": "End-user documentation site for WaaS and waas-images (Docusaurus, GitHub Pages)",
  "scripts": {
    "docusaurus": "docusaurus",
    "gen:crd": "node scripts/generate-crd-docs.mjs",
    "prestart": "npm run gen:crd",
    "start": "docusaurus start",
    "prebuild": "npm run gen:crd",
    "build": "docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "typecheck": "tsc"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.2",
    "@docusaurus/preset-classic": "^3.10.2",
    "@docusaurus/theme-mermaid": "^3.10.2",
    "@mdx-js/react": "^3.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.2",
    "@docusaurus/tsconfig": "^3.10.2",
    "@docusaurus/types": "^3.10.2",
    "typescript": "~5.6.2"
  }
}
